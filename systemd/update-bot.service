[Unit]
Description=Telegram listener for Arch update callbacks
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
Restart=always
RestartSec=10
EnvironmentFile=%h/.config/update-bot.env
ExecStart=%h/.local/bin/uv run %h/scripts/update_bot.py

[Install]
WantedBy=default.target
